/*
 * ============================================================
 * NUCLEO-G474RE Device Tree Overlay
 * ============================================================
 */

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <zephyr/dt-bindings/adc/adc.h>

/ {

    aliases {
        /*
         * FIX: alias names use hyphens (DTS convention).
         * Alias values must reference the node label, not the node name.
         */
        flow-sensor    = &flow_sensor_input;
        heartbeat-led  = &heartbeat_led_pc4;
    };

    /*
     * ============================================================
     * HEARTBEAT LED — PC4
     * ============================================================
     * FIX: Added `compatible` property. GPIO nodes that are NOT
     * child nodes of a gpio controller must use
     * "gpio-leds" compatible so Zephyr's GPIO_DT_SPEC_GET
     * can bind to them as a gpio-led device.
     * ============================================================
     */
    leds {
        compatible = "gpio-leds";

        heartbeat_led_pc4: heartbeat_led_pc4 {
            gpios = <&gpioc 4 GPIO_ACTIVE_HIGH>;
            label = "Heartbeat LED PC4";
        };
    };

    /*
     * ============================================================
     * FLOW SENSOR — PC2 (YF-S401 Pulse Input)
     * ============================================================
     * FIX: Added `compatible = "gpio-keys"` so the GPIO_DT_SPEC_GET
     * macro can resolve the node at build time.
     * ============================================================
     */
    gpio_keys {
        compatible = "gpio-keys";

        flow_sensor_input: flow_sensor_input {
            gpios = <&gpioc 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
            label = "Flow Sensor Input PC2";
        };
    };

};

/*
 * ============================================================
 * PRESSURE SENSOR — ADC1 Channel 1 (PA0)
 * ============================================================
 */
&adc1 {

    status = "okay";

    #address-cells = <1>;
    #size-cells    = <0>;

    channel@1 {
        reg = <1>;

        zephyr,gain            = "ADC_GAIN_1";
        zephyr,reference       = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution      = <12>;

        /*
         * FIX: `zephyr,input-positive` is required on STM32 ADC nodes
         * to select the physical pin. PA0 = STM32_PIN(A, 0) = channel 1
         * on ADC1. The macro resolves to the correct integer for the HAL.
         */
        zephyr,input-positive = <1>;   /* ADC1_IN1 = PA0 */
    };
};

/*
 * ============================================================
 * LCD DISPLAY — I2C1
 * PB8 → SCL  /  PB9 → SDA
 * ============================================================
 */
&i2c1 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;

    /*
     * FIX: pinctrl must be declared for STM32 I2C nodes.
     * The NUCLEO-G474RE board file already maps i2c1_default
     * to PB8/PB9, so we just reference it here.
     */
    pinctrl-0    = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
    pinctrl-names = "default";
};

/*
 * ============================================================
 * FDCAN1
 * PA11 → RX  /  PA12 → TX
 * ============================================================
 * FIX: pinctrl must be declared. STM32G474 FDCAN1 default
 * mapping is PA11 (RX) / PA12 (TX) via fdcan1_default group.
 * bus-speed and sample-point are required for CAN-FD.
 * ============================================================
 */
&fdcan1 {
    status        = "okay";
    pinctrl-0     = <&fdcan1_rx_pa11 &fdcan1_tx_pa12>;
    pinctrl-names = "default";

    /*
     * Nominal bit-rate  : 500 kbit/s  → bus-speed = 500000
     * Data   bit-rate   : 2 Mbit/s   → bus-speed-data = 2000000
     * Sample point 87.5 % = 875 (in 0.1 % units)
     */
    bus-speed        = <500000>;
    bus-speed-data   = <2000000>;
    sample-point     = <875>;
    sample-point-data = <750>;
};