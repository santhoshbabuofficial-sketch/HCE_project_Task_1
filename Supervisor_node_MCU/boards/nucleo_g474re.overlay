/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * Supervisor Node MCU
 * Board : STM32 NUCLEO-G474RE
 * RTOS  : Zephyr 3.7 LTS
 */

/ {
    aliases {
        canbus0 = &fdcan1;
        alarm-led = &alarm_led;
    };

    chosen {
        zephyr,canbus = &fdcan1;
    };
};

/* ============================================================
 * FDCAN1 CONFIGURATION (CAN BUS)
 * PA11 -> RX
 * PA12 -> TX
 * ============================================================
 */
&fdcan1 {
    status = "okay";
    pinctrl-0 = <&fdcan1_rx_pa11 &fdcan1_tx_pa12>;
    pinctrl-names = "default";
};

/* ============================================================
 * GPIO CONFIGURATION
 * PC4 -> ALARM / HEARTBEAT LED
 * ============================================================
 */
/ {
    leds {
        compatible = "gpio-leds";

        alarm_led: alarm_led {
            gpios = <&gpioc 4 GPIO_ACTIVE_HIGH>;
            label = "ALARM_LED_PC4";
        };
    };
};