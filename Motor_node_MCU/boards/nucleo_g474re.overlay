#include <zephyr/dt-bindings/gpio/gpio.h>

&gpiob {
    status = "okay";
};

&gpioc {
    status = "okay";
};

/ {
    aliases {
        heartbeat-led   = &heartbeat_led;
        stepper-step    = &stepper_step;
        stepper-dir     = &stepper_dir;
        stepper-enable  = &stepper_enable;
        canfd0          = &fdcan1;
    };

    heartbeat_leds {
        compatible = "gpio-leds";

        heartbeat_led: heartbeat_led {
            gpios = <&gpioc 4 GPIO_ACTIVE_HIGH>;
            label = "HEARTBEAT_LED";
        };
    };

    /* ============================================================
     * TMC2209 STEP/DIR/EN outputs
     *
     * Reuses the GPIOB pins previously wired to the L298N IN1-IN4
     * inputs (PB11-PB14). Only 3 of the 4 former pins are needed
     * for TMC2209 STEP/DIR/EN control, so PB14 is now free.
     *
     * ENABLE is GPIO_ACTIVE_LOW because the TMC2209's EN pin is
     * hardware active-low (driver outputs enabled when EN is
     * driven low). Declaring it ACTIVE_LOW here lets application
     * code treat gpio_pin_set_dt(&enable, 1) as "enable the
     * driver" regardless of the pin's physical polarity.
     * ============================================================
     */
    tmc2209_outputs {
        compatible = "gpio-leds";

        stepper_step: stepper_step {
            gpios = <&gpiob 11 GPIO_ACTIVE_HIGH>;
            label = "TMC2209_STEP";
        };

        stepper_dir: stepper_dir {
            gpios = <&gpiob 12 GPIO_ACTIVE_HIGH>;
            label = "TMC2209_DIR";
        };

        stepper_enable: stepper_enable {
            gpios = <&gpiob 13 GPIO_ACTIVE_LOW>;
            label = "TMC2209_ENABLE";
        };
    };
};

/ {
    chosen {
        zephyr,canbus = &fdcan1;
    };
};

&fdcan1 {
    status = "okay";
    pinctrl-0 = <&fdcan1_rx_pa11 &fdcan1_tx_pa12>;
    pinctrl-names = "default";
};